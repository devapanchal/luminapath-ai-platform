{
  "name": "luminapath-ai-learning-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Original AI-powered learning platform built with Next.js, Express, PostgreSQL, Redis, Cloudinary, and OpenAI.",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace backend\" \"npm run dev --workspace frontend\"",
    "start": "npm run start --workspace backend",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "check": "npm run check --workspaces --if-present",
    "install:all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "overrides": {
    "postcss": "^8.5.10",
    "next": {
      "postcss": "^8.5.10"
    }
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
